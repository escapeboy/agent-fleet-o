{
    "name": "fleetq/boruna-audit",
    "description": "Boruna cryptographic audit trail integration for FleetQ",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/redis": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "FleetQ\\BorunaAudit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FleetQ\\BorunaAudit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["FleetQ\\BorunaAudit\\BorunaAuditServiceProvider"]
        },
        "fleet": {
            "plugin": "boruna-audit",
            "name": "Boruna Audit Console",
            "min-version": "1.0.0"
        }
    },
    "minimum-stability": "stable"
}

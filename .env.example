APP_NAME="FleetQ"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Deployment mode: 'self-hosted' (default) or 'cloud'
DEPLOYMENT_MODE=self-hosted

# Auth bypass — auto-login as first user (local single-user installs only)
# Set to true to skip the login screen entirely. Only works when APP_ENV != production.
# NEVER enable this on a server accessible from the internet.
APP_AUTH_BYPASS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=agent_fleet
DB_USERNAME=agent_fleet
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_COOKIE=fleetq-session
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Required for OAuth callbacks from external providers (e.g. Lukanet, Google)
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_LOCK_DB=2

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@fleetq.net"
MAIL_FROM_NAME="${APP_NAME}"

# LLM Provider Keys — at least one required for AI features
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Dedicated key for conversation compaction LLM synthesis (optional).
# Set this when teams use BYOK and there is no platform-level provider key.
# Without it, compaction falls back to a basic text summary.
CONTEXT_COMPACTION_ANTHROPIC_API_KEY=

# Web Push (VAPID) — generate with: php artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# FleetQ Bridge relay — unified bridge daemon for self-hosted Docker
# Set RELAY_ENABLED=true and run: docker compose --profile relay up relay
# Then on your host: fleetq-bridge login --api-url http://localhost:8080 --api-key <token>
# Get your API token from Settings → Team → API Tokens
RELAY_ENABLED=false
RELAY_PORT=8070

# Legacy host bridge (alternative to relay — PHP-based, single-threaded)
# Generate a secret: php -r "echo bin2hex(random_bytes(16));"
LOCAL_AGENT_BRIDGE_SECRET=
LOCAL_AGENT_BRIDGE_URL=http://host.docker.internal:8065

# Reverb WebSocket server (bridge daemon relay)
# Generate values with: php artisan reverb:install (or set manually)
REVERB_APP_ID=fleetq
REVERB_APP_KEY=fleetq-key
REVERB_APP_SECRET=fleetq-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# Production overrides (set in .env on the server):
# REVERB_HOST=relay.fleetq.net
# REVERB_PORT=443
# REVERB_SCHEME=https
# REVERB_APP_MAX_MESSAGE_SIZE=100000
# REVERB_APP_ACCEPT_CLIENT_EVENTS_FROM=all
# REVERB_SCALING_ENABLED=true

# Outbound Connectors
TELEGRAM_BOT_TOKEN=
SLACK_WEBHOOK_URL=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
TEAMS_WEBHOOK_URL=
GOOGLE_CHAT_WEBHOOK_URL=

# Agent Memory
MEMORY_ENABLED=true
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_TTL_DAYS=90
MEMORY_TOP_K=5
MEMORY_SIMILARITY_THRESHOLD=0.7

# LiveKit Voice Agent (Enterprise only — uses LiveKit Cloud, no self-hosted server needed)
# 1. Sign up at https://livekit.io/cloud, create a project, copy credentials below
# 2. Start the voice worker: docker compose --profile voice up -d
# 3. Enable worker dispatch: set LIVEKIT_WORKER_DISPATCH=true
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WORKER_DISPATCH=false

# Voice STT/TTS providers (used by the voice worker container)
VOICE_STT_PROVIDER=deepgram        # deepgram | openai (Whisper)
VOICE_TTS_PROVIDER=openai          # openai | elevenlabs
DEEPGRAM_API_KEY=                  # required when VOICE_STT_PROVIDER=deepgram
ELEVENLABS_API_KEY=                # required when VOICE_TTS_PROVIDER=elevenlabs
VOICE_TTS_VOICE_ID=alloy           # OpenAI voice name or ElevenLabs voice ID

# Browser Skill (optional — requires browserless Docker service)
# Start with: docker compose --profile browser up -d
BROWSER_SKILL_ENABLED=false
BROWSERLESS_URL=http://browserless:3000
BROWSERLESS_TOKEN=secret

# Media Processing
MEDIA_DISK=local

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"

# Integrations — OAuth2
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Bash Sandbox Mode
# 'php'       — in-process (default, dev-friendly). SECURITY: uses string-based shell exec.
#               Only for local development. Do NOT use in production.
# 'docker'    — per-command Docker container (requires Docker socket access in horizon)
# 'just_bash' — persistent just-bash Node.js sidecar (recommended for cloud / production)
AGENT_BASH_SANDBOX_MODE=php

# just-bash sidecar (only used when AGENT_BASH_SANDBOX_MODE=just_bash)
# OSS: start with: docker compose --profile sandbox up
BASH_SIDECAR_URL=http://bash_sidecar:3001
BASH_SIDECAR_SECRET=


# Social Login (OAuth) — leave empty to disable a provider
# Google: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=${APP_URL}/auth/github/callback

# LinkedIn: https://developer.linkedin.com → Your Apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=${APP_URL}/auth/linkedin-openid/callback

# X (Twitter): https://developer.x.com → Your Apps → User authentication settings
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=${APP_URL}/auth/x/callback

# Apple Sign In: https://developer.apple.com → Certificates, Identifiers & Profiles
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=/path/to/AuthKey_XXXXXXXXXX.p8
APPLE_REDIRECT_URI=${APP_URL}/auth/apple/callback

# Comma-separated Socialite driver names whose email claim is trusted
# (email_verified_at is set immediately on auto-provisioned users).
# Leave unset to use the built-in defaults. Plugins registering custom OIDC/SAML
# drivers for corporate IdPs may append their driver name here.
# SOCIAL_VERIFIED_EMAIL_PROVIDERS=google,github,linkedin-openid,x,apple

# Boruna Deterministic Execution
# Path to the Boruna binary inside the container/host.
# Install: docker build --build-arg BORUNA_VERSION=0.3.0 ...
# or: curl -fsSL https://github.com/escapeboy/boruna/releases/latest/download/boruna-x86_64-unknown-linux-musl.tar.gz | tar xz -C /usr/local/bin
BORUNA_BINARY_PATH=/usr/local/bin/boruna

# MCP Stdio binary allowlist (comma-separated absolute paths).
# Production: set to the absolute paths of permitted MCP server binaries.
# `boruna-mcp` is bundled with the base image (Phase 2 of the Boruna integration);
# add it here to enable boruna_script Skills out of the box.
# Example: MCP_STDIO_BINARY_ALLOWLIST=/usr/local/bin/boruna-mcp,/usr/local/bin/my-mcp-server
MCP_STDIO_BINARY_ALLOWLIST=/usr/local/bin/boruna-mcp

# Local dev opt-in: set to true ONLY when allowlist is empty and you are on a local machine.
# NEVER enable in production — empty allowlist with this flag off denies all binaries (safe default).
MCP_STDIO_ALLOW_ANY_BINARY=false

# Integration OAuth2 Credentials
# Each section links to where to create the OAuth app.

# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_INTEGRATION_CLIENT_ID=
GITHUB_INTEGRATION_CLIENT_SECRET=

# Airtable: https://airtable.com/create/oauth
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=

# Mailchimp: https://mailchimp.com/developer → Registered Apps
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=

# GitLab: https://gitlab.com/-/profile/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ClickUp: https://app.clickup.com/settings/apps
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=

# Asana: https://app.asana.com/-/developer_console
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# Monday.com: https://monday.com/developers → Apps
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=

# Intercom: https://developers.intercom.com → Your Apps
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=

# Pipedrive: https://developers.pipedrive.com → Your Apps
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# Zendesk: https://developer.zendesk.com → OAuth Clients (requires subdomain)
ZENDESK_CLIENT_ID=
ZENDESK_CLIENT_SECRET=

# Freshdesk: https://developers.freshdesk.com → OAuth (requires subdomain)
FRESHDESK_CLIENT_ID=
FRESHDESK_CLIENT_SECRET=

# Sentry: https://sentry.io/settings/account/api/applications/
SENTRY_INTEGRATION_CLIENT_ID=
SENTRY_INTEGRATION_CLIENT_SECRET=

# PagerDuty: https://developer.pagerduty.com → My Apps
PAGERDUTY_CLIENT_ID=
PAGERDUTY_CLIENT_SECRET=

# Typeform: https://developer.typeform.com → My apps
TYPEFORM_CLIENT_ID=
TYPEFORM_CLIENT_SECRET=

# Calendly: https://developer.calendly.com → My Apps
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# Attio: https://attio.com/developers → OAuth Apps
ATTIO_CLIENT_ID=
ATTIO_CLIENT_SECRET=

# Confluence & Bitbucket share Atlassian OAuth credentials:
# https://developer.atlassian.com/console/myapps/
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# LiveKit — Real-time voice agent sessions
# Self-hosted: https://github.com/livekit/livekit | Cloud: https://livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=3600

# Voice STT/TTS providers (used by the Python voice worker)
VOICE_STT_PROVIDER=deepgram   # deepgram|whisper
VOICE_TTS_PROVIDER=openai     # openai|elevenlabs
VOICE_TTS_VOICE_ID=alloy
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OpenTelemetry — Traces, spans, LLM observability
# Off by default. Set OTEL_ENABLED=true and point OTEL_EXPORTER_OTLP_ENDPOINT
# at any OTLP-compatible collector. See docs/observability.md for provider
# recipes (Logfire, Honeycomb, Grafana Tempo, SigNoz, self-hosted Jaeger).
# ─────────────────────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=fleetq
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=production

# OTLP HTTP/protobuf endpoint. Default assumes local otel-collector sidecar.
# For Pydantic Logfire cloud:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://logfire-api.pydantic.dev
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer ${LOGFIRE_WRITE_TOKEN}
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_TIMEOUT=5.0
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
OTEL_EXPORTER_OTLP_HEADERS=

# 0.0..1.0 — 1.0 exports every span, 0.1 samples 10%. Lower in high-traffic prod.
OTEL_SAMPLE_RATE=1.0

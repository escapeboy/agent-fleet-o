includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/

    level: 5

    checkModelProperties: true
    noEnvCallsOutsideOfConfig: true
    reportUnmatchedIgnoredErrors: false

    excludePaths:
        - app/Console/Commands/InstallCommand.php

    ignoreErrors:
        # Feedback MCP tools reference Cloud-namespace classes not present in the base repo
        - '#Cloud\\Domain\\Feedback\\#'
        # Admin billing tool references Stripe SDK which is a cloud-only dependency
        - '#Stripe\\#'

services:
    -
        class: App\Infrastructure\Analysis\Rules\DomainImportBoundaryRule
        tags:
            - phpstan.rules.rule

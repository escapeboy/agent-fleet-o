parameters:
	ignoreErrors:
		-
			message: '#^Offset ''watchdog_enabled'' on string on left side of \?\? does not exist\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Console/Commands/RunSentryWatchdog.php

		-
			message: '#^Call to function in_array\(\) with arguments string, array\{App\\Domain\\Signal\\Enums\\SignalStatus\:\:DelegatedToAgent, App\\Domain\\Signal\\Enums\\SignalStatus\:\:AgentFixing, App\\Domain\\Signal\\Enums\\SignalStatus\:\:Resolved, App\\Domain\\Signal\\Enums\\SignalStatus\:\:Dismissed\} and true will always evaluate to false\.$#'
			identifier: function.impossibleType
			count: 1
			path: app/Domain/Signal/Actions/TriageSentryIssueAction.php

		-
			message: '#^Call to function in_array\(\) with arguments string, array\{App\\Domain\\Signal\\Enums\\SignalStatus\:\:DelegatedToAgent, App\\Domain\\Signal\\Enums\\SignalStatus\:\:AgentFixing, App\\Domain\\Signal\\Enums\\SignalStatus\:\:Review, App\\Domain\\Signal\\Enums\\SignalStatus\:\:InProgress\} and true will always evaluate to false\.$#'
			identifier: function.impossibleType
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Cannot access property \$value on string\.$#'
			identifier: property.nonObject
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Cannot call method isTerminal\(\) on string\.$#'
			identifier: method.nonObject
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Method App\\Domain\\Signal\\Listeners\\CloseSentryIssueOnPrMergeListener\:\:postClosureNote\(\) is unused\.$#'
			identifier: method.unused
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Method App\\Domain\\Signal\\Listeners\\CloseSentryIssueOnPrMergeListener\:\:resolveSentryIntegration\(\) is unused\.$#'
			identifier: method.unused
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Method App\\Domain\\Signal\\Listeners\\CloseSentryIssueOnPrMergeListener\:\:resolveSentryIssue\(\) is unused\.$#'
			identifier: method.unused
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Method App\\Domain\\Signal\\Listeners\\CloseSentryIssueOnPrMergeListener\:\:stampResolution\(\) is unused\.$#'
			identifier: method.unused
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Property App\\Domain\\Signal\\Listeners\\CloseSentryIssueOnPrMergeListener\:\:\$updateStatus is never read, only written\.$#'
			identifier: property.onlyWritten
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Result of \|\| is always true\.$#'
			identifier: booleanOr.alwaysTrue
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Unreachable statement \- code above always terminates\.$#'
			identifier: deadCode.unreachable
			count: 1
			path: app/Domain/Signal/Listeners/CloseSentryIssueOnPrMergeListener.php

		-
			message: '#^Offset ''watchdog_enabled'' on string on left side of \?\? does not exist\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Mcp/Tools/Signal/SentryWatchdogRunTool.php
